{
  "version": 2,
  "builds": [
    { "src": "package.json", "use": "@vercel/static-build", "config": { "distDir": "dist" } }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "https://gestion-clinique.onrender.com/api/$1" },
    { "handle": "filesystem" },
    { "src": "^/(?!api/)(?!.*\\.[^/]+$)(.*)$", "dest": "/index.html" }
  ]
}

